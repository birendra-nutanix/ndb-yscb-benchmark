        "targets": [
          {
            "datasource": {
              "type": "influxdb",
              "uid": "influxdb-jmx-metrics"
            },
            "query": "from(bucket: \"tomcat_jmx_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"ndb_operations\")\n  |> filter(fn: (r) => r[\"engine\"] == \"${engine}\")\n  |> filter(fn: (r) => r[\"database_type\"] == \"${database_type}\")\n  |> filter(fn: (r) => r[\"operation_type\"] == \"${operation_type}\")\n  |> drop(columns: [\"_start\", \"_stop\", \"_measurement\"])\n  |> pivot(rowKey: [\"_time\", \"operation_id\", \"database\", \"engine\", \"database_type\", \"operation_type\", \"status\", \"ndb_ip\", \"ndb_version\", \"commit_id\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> group()\n  |> rename(columns: {_time: \"Time\"})\n  |> sort(columns: [\"Time\"], desc: true)",
            "refId": "A"
          }
        ],
        "title": "operation detail",
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "count": true
              },
              "indexByName": {
                "Time": 7,
                "commit_id": 8,
                "count": 10,
                "database": 5,
                "database_type": 4,
                "duration_ms": 11,
                "engine": 3,
                "ndb_ip": 0,
                "ndb_version": 1,
                "operation_id": 2,
                "operation_type": 6,
                "percentage_complete": 12,
                "status": 9
              },
              "renameByName": {
                "duration_ms": "duration",
                "percentage_complete": "percentage"
              }
            }
          }
        ],
        "type": "table"
      }
